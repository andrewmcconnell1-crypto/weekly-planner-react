# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings -> API). Both are safe to expose in the browser;
# data is protected by row-level security in the database.
#
# Without these set, the app runs in local-only mode (no sign-in, data stays in
# the browser).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
